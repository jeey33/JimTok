<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>JiMToK</title>

<style>

body{
    margin:0;
    font-family:Arial, sans-serif;
    background:#0d1117;
    color:white;
    text-align:center;
}

.container{
    padding:40px 20px;
}

.logo{
    font-size:60px;
    font-weight:bold;
    margin-top:50px;
    color:#00ffb3;
    text-shadow:0 0 20px #00ffb3;
}

.subtitle{
    font-size:22px;
    color:#999;
    margin-top:10px;
}

.card{
    background:#161b22;
    max-width:500px;
    margin:50px auto;
    padding:40px;
    border-radius:25px;
    box-shadow:0 0 30px rgba(0,255,179,0.15);
}

button{
    background:#00ffb3;
    color:black;
    border:none;
    padding:18px 30px;
    font-size:18px;
    border-radius:15px;
    cursor:pointer;
    margin-top:20px;
    font-weight:bold;
    transition:0.3s;
}

button:hover{
    transform:scale(1.05);
    background:white;
}

.wallet{
    margin-top:25px;
    font-size:18px;
    color:#00ffb3;
}

.footer{
    margin-top:60px;
    color:#666;
    font-size:14px;
}

.dust{
    font-size:80px;
    margin-top:20px;
    animation:float 3s infinite ease-in-out;
}

@keyframes float{
    0%{transform:translateY(0px);}
    50%{transform:translateY(-15px);}
    100%{transform:translateY(0px);}
}

</style>
</head>

<body>

<div class="container">

<div class="logo">
JiMToK
</div>

<div class="subtitle">
Turn crypto dust into value
</div>

<div class="dust">
🧹
</div>

<div class="card">

<h2>Clean Your Wallet</h2>

<p>
Millions of wallets contain useless tiny balances.
JiMToK gives them a second life.
</p>

<button onclick="connectWallet()">
Connect Wallet
</button>

<br>

<button onclick="convertDust()">
Convert Dust
</button>

<div class="wallet" id="walletStatus">
Wallet not connected
</div>

</div>

<div class="footer">
JiMToK © 2026
</div>

</div>

<script>

function connectWallet(){

    document.getElementById("walletStatus").innerHTML =
    "Wallet Connected ✅";

}

function convertDust(){

    document.getElementById("walletStatus").innerHTML =
    "Dust converted to JiMToK 🚀";

}

</script>

</body>
</html>